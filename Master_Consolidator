def is_organization_name(name, extra_indicators=None, email=None) -> bool:
    if pd.isna(name) or not name: return False
    name_lower = str(name).lower()

    org_indicators = {
        'inc', 'llc', 'corp', 'corporation', 'company', 'co', 'ltd', 'limited',
        'foundation', 'fund', 'trust', 'association', 'assoc', 'charity', 'associates',
        'church', 'ministry', 'parish', 'chapel', 'school', 'university', 'college',
        'academy', 'institute', 'hospital', 'clinic', 'medical', 'health',
        'bank', 'credit union', 'financial', 'insurance', 'wealth', 'group', 'partners',
        'partnership', 'services', 'solutions', 'consulting', 'advisors', 'law',
        'council', 'commission', 'committee', 'board', 'society', 'club',
        'lodge', 'chapter', 'county', 'city', 'town', 'village', 'district',
        'department', 'dept', 'authority', 'agency', 'bureau', 'office',
        'store', 'shop', 'market', 'restaurant', 'cafe', 'bar', 'grill',
        'realty', 'realtor', 'properties', 'real estate', 'construction', 'builders', 'roofing', 'plumbing',
        'farm', 'farms', 'ranch', 'nursery', 'garden', 'landscaping',
        'auto', 'motors', 'automotive', 'tire', 'towing',
        'electric', 'power', 'energy', 'gas', 'water', 'utility',
        'media', 'press', 'publishing', 'news', 'radio', 'tv', 'broadcasting',
        'tech', 'technology', 'software', 'network', 'hardware',
        'nonprofit', 'ngo', 'outfitters', 'brewery', 'brewing', 'distillery', 'pllc'
    }
    if extra_indicators:
        org_indicators.update({str(w).lower() for w in extra_indicators})

    clean_words = set(re.findall(r'\b[a-z]+\b', name_lower))
    if clean_words.intersection(org_indicators):
        return True

    if email and pd.notna(email) and '@' in str(email):
        free_domains = {'gmail.com', 'yahoo.com', 'hotmail.com', 'aol.com', 'outlook.com', 'icloud.com', 'mac.com', 'msn.com', 'live.com'}
        domain_full = str(email).split('@')[-1].lower().strip()
        if domain_full not in free_domains:
            domain_main = domain_full.split('.')[0]
            name_compressed = re.sub(r'[^a-z]', '', name_lower)
            if len(domain_main) >= 4 and (domain_main in name_compressed or name_compressed in domain_main):
                return True
    return False

def clean_string(val):
    if pd.isna(val): return None
    val = str(val).strip()
    return None if val.lower() in ('', 'nan', 'none', 'n/a', 'na', 'null') else val

def clean_name(val):
    val = clean_string(val)
    return re.sub(r'\s+', ' ', val).title() if val else None

def clean_email(val):
    val = clean_string(val)
    return val.lower().strip() if val and '@' in val and '.' in val.split('@')[-1] else None

def clean_phone(val):
    if pd.isna(val): return None
    digits = re.sub(r'\D', '', str(val))
    if len(digits) == 11 and digits[0] == '1': digits = digits[1:]
    if len(digits) == 10: return f"({digits[:3]}) {digits[3:6]}-{digits[6:]}"
    elif len(digits) == 7: return f"{digits[:3]}-{digits[3:]}"
    return digits if len(digits) > 0 else None

def clean_zip(val):
    if pd.isna(val): return None
    val = re.sub(r'\.0$', '', str(val).strip())
    match = re.match(r'(\d{5})(-\d{4})?', val)
    if match: return match.group(0)
    digits = re.sub(r'\D', '', val)
    return digits[:5] if len(digits) >= 5 else clean_string(val)

def normalize_for_matching(val):
    return re.sub(r'[^a-z0-9]', '', str(val).lower().strip()) if pd.notna(val) and val else ''

def normalize_name_for_matching(name):
    if pd.isna(name) or name is None: return ''
    name = re.sub(r'\b(jr|sr|ii|iii|iv|v|esq|md|phd|dds)\b\.?', '', str(name).lower().strip())
    name = re.sub(r'^(mr|mrs|ms|miss|dr|rev|fr|sr|hon)\.?\s+', '', name)
    nickname_map = {'bob':'robert','jim':'james','mike':'michael','tom':'thomas','dick':'richard','joe':'joseph','dave':'david','dan':'daniel','pat':'patrick','steve':'steven','ed':'edward','al':'albert','charlie':'charles','jack':'john','sam':'samuel','ben':'benjamin','jerry':'gerald','larry':'lawrence','liz':'elizabeth','kathy':'katherine','sue':'susan','jenny':'jennifer','debbie':'deborah','nancy':'ann','peggy':'margaret','barb':'barbara','chris':'christopher','alex':'alexander','matt':'matthew','andy':'andrew','don':'donald','ron':'ronald','fred':'frederick','ken':'kenneth'}
    words = re.sub(r'[^a-z\s]', '', name).strip().split()
    if words: words[0] = nickname_map.get(words[0], words[0])
    return re.sub(r'[^a-z0-9]', '', ''.join(words))

def make_person_key(first_name, last_name, email=None):
    email_clean = clean_email(email)
    if email_clean: return f"email:{email_clean}"
    fn, ln = normalize_name_for_matching(first_name), normalize_name_for_matching(last_name)
    if fn and ln: return f"name:{fn}:{ln}"
    return f"unknown:{hashlib.md5(f'{first_name}{last_name}{email}'.encode()).hexdigest()[:12]}"

def make_address_key(address, city, zip_code):
    addr, cty, zp = normalize_for_matching(address), normalize_for_matching(city), normalize_for_matching(zip_code)
    return f"{addr}|{cty}|{zp}" if addr and (cty or zp) else None

