                    'affiliation_type': 'Employee/Contact', 'is_primary_affiliation': True, 'is_active': True
                })
                affiliations_created += 1

        if spouses_created or affiliations_created:
            logger.info(f"  ✓ Created {spouses_created} new spouse records from JSON")
            logger.info(f"  ✓ Linked {affiliations_created} individuals to Organizations from JSON")

    def assign_households(self):
        logger.info("\n--- Assigning Households ---")
        addr_to_hh = {self._normalize_address(hh.get('address_line1'), hh.get('city')): hh for hh in self.households.values() if self._normalize_address(hh.get('address_line1'), hh.get('city'))}
        phone_to_hh = {self._normalize_phone_digits(hh.get('phone')): hh for hh in self.households.values() if self._normalize_phone_digits(hh.get('phone'))}

        email_to_hh = {}
        for hh in self.households.values():
            for mk in hh.get('_member_keys', []):
                for e in self.people.get(mk, {}).get('_all_emails', set()):
                    if e: email_to_hh[e] = hh

        for pk, person in self.people.items():
            if person.get('household_id'): continue

            addr_norm = self._normalize_address(person.get('address_line1'), person.get('city'))
            if addr_norm and addr_norm in addr_to_hh:
                person['household_id'] = addr_to_hh[addr_norm]['household_id']
                if pk not in addr_to_hh[addr_norm]['_member_keys']: addr_to_hh[addr_norm]['_member_keys'].append(pk)
                if not addr_to_hh[addr_norm].get('primary_contact_id'): addr_to_hh[addr_norm]['primary_contact_id'] = person['donor_id']
                continue

            ph = self._normalize_phone_digits(person.get('phone'))
            if ph and ph in phone_to_hh and phone_to_hh[ph].get('household_id'):
                person['household_id'] = phone_to_hh[ph]['household_id']
                if pk not in phone_to_hh[ph]['_member_keys']: phone_to_hh[ph]['_member_keys'].append(pk)
                continue

            if person.get('email') and person['email'] in email_to_hh:
                person['household_id'] = email_to_hh[person['email']]['household_id']
                if pk not in email_to_hh[person['email']]['_member_keys']: email_to_hh[person['email']]['_member_keys'].append(pk)
                continue

            hh_id = self.find_or_create_household(
                pk, household_name=f"{person.get('first_name', '')} {person.get('last_name', '')} Household".strip(),
                address=person.get('address_line1'), city=person.get('city'), state=person.get('state'),
                zip_code=person.get('zip_code'), phone=person.get('phone'), is_member=person.get('is_member', False),
                membership_level=person.get('membership_level'), membership_start_date=person.get('membership_start_date'),
                membership_expiration_date=person.get('membership_expiration_date'), membership_status=person.get('membership_status')
            )
            person['household_id'] = hh_id
            if addr_norm: addr_to_hh[addr_norm] = self.households.get(make_address_key(person.get('address_line1'), person.get('city'), person.get('zip_code')) or f"hh_{hh_id}", {})
            if ph: phone_to_hh[ph] = self.households.get(f"hh_{hh_id}", {})

    MEMBERSHIP_TIERS = [(2000, float('inf'), 'Major Donor'), (500, 1999.99, 'Patron'), (200, 499.99, 'Donor'), (100, 199.99, 'Sponsor'), (50, 99.99, 'Supporter'), (25, 49.99, 'Contributor')]

    def calculate_memberships(self):
        cy = datetime.now().year
        donor_annual = defaultdict(lambda: defaultdict(lambda: {'total': 0.0, 'explicit': False}))

        for d in self.donations:
            did, amt, dt = d.get('donor_id'), d.get('amount', 0) or 0, d.get('donation_date')
            if not did or amt <= 0 or not dt: continue
            try: yr = dt.year if hasattr(dt, 'year') else datetime.strptime(dt, '%Y-%m-%d').year
            except: continue
            donor_annual[did][yr]['total'] += amt
            if 'membership levels' in (d.get('_form_name', '') or '').lower(): donor_annual[did][yr]['explicit'] = True

        for pk, person in self.people.items():
            did = person['donor_id']
            best_amt, best_yr, is_explicit, has_mem = 0, None, False, False

            for yr in range(cy - 1, cy + 1):
                tot = donor_annual[did][yr]['total']
                if tot >= 25:
                    has_mem = True
                    if tot > best_amt: best_amt, best_yr = tot, yr
                    if donor_annual[did][yr]['explicit']: is_explicit = True

            if has_mem:
                person['is_member'], person['membership_status'], person['membership_type'] = True, 'Active', 'Explicit' if is_explicit else 'Non-Explicit'
                for mn, mx, lvl in self.MEMBERSHIP_TIERS:
                    if mn <= best_amt <= mx: person['membership_level'] = lvl
                person['membership_start_date'] = datetime(best_yr, 1, 1).date() if not person.get('membership_start_date') else person['membership_start_date']
                person['membership_expiration_date'] = datetime(best_yr + 1, 12, 31).date()
            elif person.get('is_member') and person.get('membership_level'):
                person['membership_type'] = 'Source System'
                exp = person.get('membership_expiration_date')
                if exp and exp < datetime.now().date(): person['membership_status'] = 'Expired'
            else:
                person['is_member'], person['membership_level'], person['membership_status'] = False, None, None

        hh_mem = defaultdict(lambda: {'is_member': False, 'best_level': None, 'start': None, 'exp': None, 'status': None, 'type': None})
        tp = {lvl: i for i, (_, _, lvl) in enumerate(self.MEMBERSHIP_TIERS)}
        for person in self.people.values():
            if person.get('household_id') and person.get('is_member') and person.get('membership_level'):
                hid = person['household_id']
                if tp.get(person['membership_level'], 999) < tp.get(hh_mem[hid]['best_level'], 999):
                    hh_mem[hid].update({'is_member': True, 'best_level': person['membership_level'], 'start': person.get('membership_start_date'), 'exp': person.get('membership_expiration_date'), 'status': person.get('membership_status'), 'type': person.get('membership_type')})

        for hh in self.households.values():
            if hh['household_id'] in hh_mem:
                m = hh_mem[hh['household_id']]
                hh.update({'is_member': m['is_member'], 'membership_level': m['best_level'], 'membership_start_date': m['start'], 'membership_expiration_date': m['exp'], 'membership_status': m['status'], 'membership_type': m['type']})

    def dedupe_donations(self):
        logger.info("\n--- Deduplicating Donations ---")
        if not self.donations: return

        def pd(d):
            dt = d.get('donation_date')
            if hasattr(dt, 'year'): return dt
            try: return datetime.strptime(str(dt), '%Y-%m-%d').date()
            except: return None

        qb_by_amt = defaultdict(list)
        for i, d in enumerate(self.donations):
            if d.get('transaction_id') or 'qgiv' in (d.get('notes') or '').lower():
                dt = pd(d)
                if dt and d.get('amount'): qb_by_amt[round(float(d['amount']), 2)].append({'did': d['donor_id'], 'dt': dt, 'idx': i})

        seen_dupes = set()
        for i, d in enumerate(self.donations):
            if 'quickbooks' in (d.get('notes') or '').lower():
                dt, amt = pd(d), d.get('amount')
                if dt and amt:
                    for q in qb_by_amt.get(round(float(amt), 2), []):
                        if abs((dt - q['dt']).days) <= 7 and d['donor_id'] == q['did']:
                            seen_dupes.add(i)
                            break

        exact_seen = set()
        final_donations = []
        for i, d in enumerate(self.donations):
            if i in seen_dupes: continue
            k = (d.get('donor_id'), str(d.get('donation_date')), str(round(float(d.get('amount', 0)), 2)), d.get('transaction_id'))
            if k not in exact_seen:
                exact_seen.add(k)
                final_donations.append(d)

        logger.info(f"  ✓ Removed {len(self.donations) - len(final_donations)} duplicate donations")
        self.donations = final_donations

    def process_pending_resolutions(self):
        """Creates new spouse records and organization affiliations flagged by manual review."""
        logger.info("\n--- Executing Manual Resolutions (Spouses & Affiliations) ---")

        # We use list(self.people.items()) because we are adding new people while looping
        for pk, person in list(self.people.items()):

            # Handle Spouse Splits
            for spouse in person.get('_pending_spouses', []):
                self.register_person(
                    first_name=spouse['first_name'],
                    last_name=spouse['last_name'],
                    email=spouse.get('email'),
                    phone=spouse.get('phone'),
                    address_line1=person.get('address_line1'),
                    city=person.get('city'),
                    state=person.get('state'),
                    zip_code=person.get('zip_code'),
                    source='manual_spouse_split'
                )

            # Handle Work Affiliations
            for org_name in person.get('_pending_affiliations', []):
                org_id = self.find_or_create_organization(org_name, organization_type='Business')
                self.donor_org_affiliations.append({
                    'donor_id': person['donor_id'],
                    'organization_id': org_id,
                    'affiliation_type': 'Employee/Contact',
                    'is_primary_affiliation': True,
                    'is_active': True
                })

    def export_all(self, output_dir: str):
        os.makedirs(output_dir, exist_ok=True)
        dl = {p['donor_id']: p for p in self.people.values()}

        pd.DataFrame([{**hh, 'primary_contact_name': f"{dl.get(hh.get('primary_contact_id'), {}).get('first_name', '')} {dl.get(hh.get('primary_contact_id'), {}).get('last_name', '')}".strip()} for hh in self.households.values()]).to_csv(os.path.join(output_dir, 'master_households.csv'), index=False)
        pd.DataFrame(self.people.values()).to_csv(os.path.join(output_dir, 'master_donors.csv'), index=False)
        pd.DataFrame(self.organizations.values()).to_csv(os.path.join(output_dir, 'master_organizations.csv'), index=False)
        pd.DataFrame([{**v, 'first_name': v.get('first_name') or self.people.get(v.get('_person_key'), {}).get('first_name')} for v in self.volunteer_records.values()]).to_csv(os.path.join(output_dir, 'master_volunteers.csv'), index=False)

        if self.donations:
            df_d = pd.DataFrame(self.donations)
            df_d['donor_first_name'] = df_d['donor_id'].map(lambda id: dl.get(id, {}).get('first_name'))
            df_d['donor_last_name'] = df_d['donor_id'].map(lambda id: dl.get(id, {}).get('last_name'))
            df_d.to_csv(os.path.join(output_dir, 'master_donations.csv'), index=False)

        if self.donor_org_affiliations: pd.DataFrame(self.donor_org_affiliations).to_csv(os.path.join(output_dir, 'master_donor_org_affiliations.csv'), index=False)

