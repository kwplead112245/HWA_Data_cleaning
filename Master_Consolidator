    def process_qgiv(self, df: pd.DataFrame):
        logger.info("\n--- Processing Qgiv Transactions ---")
        donation_count, skipped_amount = 0, 0

        for _, row in df.iterrows():
            first_name = clean_string(row.get('First Name'))
            last_name = clean_string(row.get('Last Name'))
            email = clean_email(row.get('Email'))
            phone = clean_phone(row.get('Phone'))
            company = clean_string(row.get('Company'))

            if not first_name and not last_name and not email and not company:
                continue

            # ==========================================================
            # ORG INTERCEPT: Did they put the company in the name fields?
            # ==========================================================
            combined_name = f"{first_name or ''} {last_name or ''}".strip()
            if not company and is_organization_name(combined_name, email=email):
                company = combined_name
                first_name = None
                last_name = None

            person_key = None
            if first_name or last_name or email:
                person_key = self.register_person(
                    first_name=first_name, last_name=last_name, email=email, source='qgiv',
                    phone=phone, address_line1=row.get('Address'), city=row.get('City'),
                    state=row.get('State'), zip_code=row.get('Zip'), country=row.get('Country'),
                )

            amount = row.get('Total Amount') or row.get('Line Amount')
            if pd.notna(amount):
                try: amount = float(str(amount).replace('$', '').replace(',', ''))
                except: amount = None

            if amount and amount > 0:
                donation_date = pd.to_datetime(row.get('Date'), errors='coerce')

                org_id = None
                if company:
                    org_id = self.find_or_create_organization(company, organization_type='Donor')
                    if person_key and org_id:
                        self.donor_org_affiliations.append({
                            'donor_id': self.people[person_key]['donor_id'], 'organization_id': org_id,
                            'affiliation_type': 'Employee', 'is_primary_affiliation': True, 'is_active': True,
                        })

                self.donations.append({
                    'donation_id': self._next_donation_id(),
                    'donor_id': self.people[person_key]['donor_id'] if person_key else None,
                    'donation_date': donation_date.date() if pd.notna(donation_date) else None,
                    'amount': amount, 'payment_method': clean_string(row.get('Payment Method')),
                    'check_number': clean_string(row.get('Check Number')), 'transaction_id': clean_string(row.get('Transaction ID')),
                    'donation_type': self._map_qgiv_type(row), 'is_membership_donation': self._is_membership_donation(row),
                    'membership_level': None, 'is_tax_deductible': True, 'acknowledgment_sent': False,
                    'notes': self._build_qgiv_notes(row), 'organization_id': org_id if not person_key else None,
                    '_form_name': clean_string(row.get('Form Name')),
                })
                donation_count += 1
            else:
                skipped_amount += 1

            if person_key and clean_string(row.get('Recurring ID')):
                self.people[person_key]['_has_recurring'] = True
                self.people[person_key]['_recurring_freq'] = clean_string(row.get('Recurring Frequency'))
                self.people[person_key]['_recurring_id'] = clean_string(row.get('Recurring ID'))

            if person_key and clean_string(row.get('Event Name')):
                self.people[person_key]['_events'] = self.people[person_key].get('_events', [])
                self.people[person_key]['_events'].append(clean_string(row.get('Event Name')))

        logger.info(f"  ✓ {donation_count} donations recorded")

    def _map_qgiv_type(self, row):
        qt, ft = clean_string(row.get('Type')), clean_string(row.get('Form Type'))
        if qt and 'recurr' in qt.lower(): return 'Recurring'
        if ft and 'event' in ft.lower(): return 'Event'
        if ft and 'peer' in ft.lower(): return 'Peer-to-Peer'
        return 'One-Time'

    def _is_membership_donation(self, row):
        for field in [clean_string(row.get('Line Item')), clean_string(row.get('Form Name')), clean_string(row.get('Restriction'))]:
            if field and any(kw in field.lower() for kw in ['member', 'membership', 'dues']): return True
        return False

    def _build_qgiv_notes(self, row):
        parts = [f"{k}: {clean_string(row.get(v))}" for k, v in [("Form", 'Form Name'), ("Event", 'Event Name'), ("Source", 'Source'), ("Memo", 'Memo')] if clean_string(row.get(v))]
        return ' | '.join(parts) if parts else None

    def process_quickbooks(self, df: pd.DataFrame):
        logger.info("\n--- Processing QuickBooks Donations ---")
        donation_count, membership_count, skipped = 0, 0, 0
        df.columns = [c.strip().lower() for c in df.columns]

        for _, row in df.iterrows():
            full_name = clean_string(row.get('name'))
            amount = row.get('amount')
            if pd.notna(amount):
                try: amount = float(str(amount).replace('$', '').replace(',', ''))
                except: amount = None

            if not full_name or not amount or amount <= 0:
                skipped += 1
                continue

            donation_date = pd.to_datetime(row.get('date'), errors='coerce')
            dt_raw = clean_string(row.get('type')) or ''
            is_mem = 'membership' in dt_raw.lower()

            # ==========================================================
            # ORG INTERCEPT: Is QuickBooks handing us a business?
            # ==========================================================
            if is_organization_name(full_name, extra_indicators=['rotary', 'kiwanis', 'watershed']):
                org_id = self.find_or_create_organization(full_name, organization_type='Donor')
                self.donations.append({
                    'donation_id': self._next_donation_id(), 'donor_id': None,
                    'donation_date': donation_date.date() if pd.notna(donation_date) else None,
                    'amount': amount, 'payment_method': 'Offline', 'check_number': None, 'transaction_id': None,
                    'donation_type': 'Membership' if is_mem else 'Donation', 'is_membership_donation': is_mem,
                    'membership_level': None, 'is_tax_deductible': True, 'acknowledgment_sent': False,
                    'notes': f"QuickBooks import | Type: {dt_raw}", 'organization_id': org_id,
                    '_form_name': 'Membership Levels' if is_mem else None,
                })
                donation_count += 1
                if is_mem: membership_count += 1
                continue

            name_parts = full_name.strip().split()
            first_name = name_parts[0]
            last_name = ' '.join(name_parts[1:]) if len(name_parts) >= 2 else 'Unknown'

            person_key = self.register_person(first_name=first_name, last_name=last_name, source='quickbooks')

            self.donations.append({
                'donation_id': self._next_donation_id(), 'donor_id': self.people[person_key]['donor_id'],
                'donation_date': donation_date.date() if pd.notna(donation_date) else None,
                'amount': amount, 'payment_method': 'Offline', 'check_number': None, 'transaction_id': None,
                'donation_type': 'Membership' if is_mem else 'Donation', 'is_membership_donation': is_mem,
                'membership_level': None, 'is_tax_deductible': True, 'acknowledgment_sent': False,
                'notes': f"QuickBooks import | Type: {dt_raw}", 'organization_id': None,
                '_form_name': 'Membership Levels' if is_mem else None,
            })
            donation_count += 1
            if is_mem: membership_count += 1

        logger.info(f"  ✓ {donation_count} QB donations recorded")

    def process_old_names(self, df: pd.DataFrame):
        logger.info("\n--- Processing Old Names Database ---")
        for _, row in df.iterrows():
            people = parse_concatenated_names(row.get('FName'), row.get('LName'), row.get('SpousesName'))
            if not people: continue

            membership_date = None
            try:
                yr, mo, dy = row.get('YrJoined'), row.get('MonJoined', 1), row.get('DayJoined', 1)
                if pd.notna(yr): membership_date = datetime(int(yr), int(mo if pd.notna(mo) else 1), int(dy if pd.notna(dy) else 1)).date()
            except: pass

            dues = row.get('Dues')
            ml = 'Patron' if pd.notna(dues) and float(dues)>=500 else 'Donor' if pd.notna(dues) and float(dues)>=200 else 'Sponsor' if pd.notna(dues) and float(dues)>=100 else 'Supporter' if pd.notna(dues) and float(dues)>=50 else 'Contributor' if pd.notna(dues) and float(dues)>=25 else 'Associate' if pd.notna(dues) else None
            last_paid = pd.to_datetime(row.get('lastPd'), errors='coerce')
            ms = 'Expired' if pd.notna(last_paid) and (datetime.now() - last_paid).days > 365 else 'Active'

            person_keys = []
            for i, person in enumerate(people):
                person_keys.append(self.register_person(
                    first_name=person['first_name'], last_name=person['last_name'],
                    email=row.get('EMail') if i==0 else None, source='old_names',
                    phone=row.get('Phone') if i==0 else None, address_line1=row.get('Add'),
                    city=row.get('City'), state=row.get('St'), zip_code=row.get('Zip'),
                    is_member=pd.notna(dues), membership_level=ml, membership_start_date=membership_date,
                    membership_status=ms, is_primary_contact=(i==0), notes=f"Old DB Type: {row.get('Type')}. Interests: {row.get('Interests', '')}",
                ))

            org_name = row.get('Organization')
            if pd.notna(org_name) and str(org_name).strip():
                org_id = self.find_or_create_organization(org_name, organization_type='Member', phone=row.get('OfficePhone'), is_member=True)
                if pd.notna(row.get('ContactPerson')) and person_keys:
                    self.donor_org_affiliations.append({'donor_id': self.people[person_keys[0]]['donor_id'], 'organization_id': org_id, 'affiliation_type': 'Contact', 'is_primary_affiliation': True, 'is_active': True})

    def process_volunteer_db(self, df: pd.DataFrame):
        logger.info("\n--- Processing Volunteer Database ---")
        for _, row in df.iterrows():
