def load_yaml_config(yaml_path: str = None) -> dict:
    search_paths = []
    if yaml_path:
        search_paths.append(yaml_path)
    script_dir = os.path.dirname(os.path.abspath(__file__))
    search_paths.append(os.path.join(script_dir, 'config.yaml'))
    search_paths.append(os.path.join(os.getcwd(), 'config.yaml'))

    for path in search_paths:
        if os.path.exists(path):
            try:
                import yaml
                with open(path, 'r') as f:
                    cfg = yaml.safe_load(f)
                logger.info(f"✓ Loaded config from {path}")
                return cfg
            except ImportError:
                return {}
            except Exception as e:
                return {}
    return {}

class Config:
    def __init__(self, yaml_path: str = None):
        cfg = load_yaml_config(yaml_path)
        dirs = cfg.get('directories', {})
        self.INPUT_DIR = dirs.get('input', 'input_data')
        self.OUTPUT_DIR = dirs.get('output', 'consolidated_output')
        self.RESOLUTIONS_FILE = os.path.join(self.OUTPUT_DIR, 'manual_resolutions.json')

        thresholds = cfg.get('thresholds', {})
        self.AUTO_MERGE_THRESHOLD = thresholds.get('auto_merge', MERGE_THRESHOLDS['auto_merge'])
        self.REVIEW_THRESHOLD = thresholds.get('review', MERGE_THRESHOLDS['review'])

        scoring = cfg.get('scoring', {})
        self.SCORING = {
            'address_match': scoring.get('address_match', SCORING_WEIGHTS['address_match']),
            'email_match': scoring.get('email_match', SCORING_WEIGHTS['email_match']),
            'phone_match': scoring.get('phone_match', SCORING_WEIGHTS['phone_match']),
            'name_exact': scoring.get('name_exact', SCORING_WEIGHTS['name_exact']),
            'name_similar': scoring.get('name_similar', SCORING_WEIGHTS['name_similar']),
        }

        sources = cfg.get('sources', {})
        if sources:
            global SOURCE_PRIORITY
            SOURCE_PRIORITY = sources

