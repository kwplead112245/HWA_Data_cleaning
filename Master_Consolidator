class MasterConsolidator:
    def __init__(self, config: Config):
        self.config = config
        self.SCORING = config.SCORING
        self.warnings = []

        # Load Manual Resolutions
        self.resolutions = {}
        if os.path.exists(config.RESOLUTIONS_FILE):
            with open(config.RESOLUTIONS_FILE, 'r') as f:
                self.resolutions = json.load(f)
            logger.info(f"✓ Loaded {len(self.resolutions)} manual resolutions from JSON.")

        self.people = {}
        self.email_index = {}
        self.name_index = {}
        self._lastname_index = {}
        self._address_index = {}
        self._phone_index = {}

        self.households = {}
        self.organizations = {}
        self.donations = []
        self.volunteer_records = {}
        self.donor_org_affiliations = []

        self._donor_id = 0
        self._household_id = 0
        self._org_id = 0
        self._volunteer_id = 0
        self._donation_id = 0

    def _next_donor_id(self) -> int:
        self._donor_id += 1
        return self._donor_id
    def _next_household_id(self) -> int:
        self._household_id += 1
        return self._household_id
    def _next_org_id(self) -> int:
        self._org_id += 1
        return self._org_id
    def _next_volunteer_id(self) -> int:
        self._volunteer_id += 1
        return self._volunteer_id
    def _next_donation_id(self) -> int:
        self._donation_id += 1
        return self._donation_id

    def find_person(self, first_name, last_name, email=None, phone=None, zip_code=None, address_line1=None, city=None):
        scores = self.SCORING
        auto_threshold = self.config.AUTO_MERGE_THRESHOLD
        review_threshold = self.config.REVIEW_THRESHOLD

        email_clean = clean_email(email)
        addr_norm = self._normalize_address(address_line1, city)
        ph_digits = self._normalize_phone_digits(phone)
        fn, ln = normalize_name_for_matching(first_name), normalize_name_for_matching(last_name)
        has_contact_info = bool(addr_norm or email_clean or ph_digits)

        candidates = set()
        if addr_norm and addr_norm in self._address_index: candidates.update(self._address_index[addr_norm])
        if email_clean and email_clean in self.email_index: candidates.add(self.email_index[email_clean])
        if ph_digits and ph_digits in self._phone_index: candidates.update(self._phone_index[ph_digits])
        if fn and ln and f"{fn}:{ln}" in self.name_index: candidates.update(self.name_index[f"{fn}:{ln}"])

        if not candidates: return None, 0

        best_key, best_score, best_breakdown = None, 0, {}

        for pk in candidates:
            person = self.people[pk]
            score = 0
            breakdown = {}

            if addr_norm and addr_norm == self._normalize_address(person.get('address_line1'), person.get('city')):
                score += scores['address_match']
                breakdown['address'] = scores['address_match']

            if email_clean and (email_clean == person.get('email') or email_clean in person.get('_all_emails', set())):
                score += scores['email_match']
                breakdown['email'] = scores['email_match']

            if ph_digits and ph_digits == self._normalize_phone_digits(person.get('phone')):
                score += scores['phone_match']
                breakdown['phone'] = scores['phone_match']

            if fn and ln:
                existing_fn = normalize_name_for_matching(person.get('first_name', ''))
                existing_ln = normalize_name_for_matching(person.get('last_name', ''))

                if fn == existing_fn and ln == existing_ln:
                    score += scores['name_exact']
                    breakdown['name_exact'] = scores['name_exact']

                    existing_has_contact = bool(person.get('email') or person.get('phone') or person.get('address_line1'))
                    if not has_contact_info and not existing_has_contact:
                        score = max(score, auto_threshold)
                        breakdown['override'] = 'exact_name_neither_has_contact'
                    elif not has_contact_info or not existing_has_contact:
                        score = max(score, auto_threshold)
                        breakdown['override'] = 'exact_name_one_blank_no_conflict'

                elif ln == existing_ln and fn and existing_fn and fn[0] == existing_fn[0]:
                    score += scores['name_similar']
                    breakdown['name_similar'] = scores['name_similar']

                elif ln == existing_ln and fn != existing_fn:
                    score = 0
                    breakdown['override'] = 'family_member_shared_info'

            if score > best_score:
                best_score = score
                best_key = pk
                best_breakdown = breakdown

        if best_score >= auto_threshold:
            return best_key, best_score
        elif best_score >= review_threshold:
            person = self.people[best_key]
            warning_id = f"REVIEW_NEEDED_{person.get('donor_id')}_{len(self.warnings)}"

            # --- RESOLUTION ENGINE INTERCEPT ---
            if warning_id in self.resolutions:
                action = self.resolutions[warning_id].get('action')
                if action == 'merge': return best_key, 100
                elif action == 'separate': return None, 0
                elif action == 'merge_and_affiliate':
                    org_name = self.resolutions[warning_id].get('org_name')
                    person['_pending_affiliations'] = person.get('_pending_affiliations', [])
                    person['_pending_affiliations'].append(org_name)
                    return best_key, 100

            self.warnings.append({
                'type': 'REVIEW_NEEDED',
                'confidence_score': best_score,
                'score_breakdown': str(best_breakdown),
                'message': f"Score {best_score}: '{first_name} {last_name}' might be '{person.get('first_name')} {person.get('last_name')}'",
                'new_email': email_clean,
                'new_phone': clean_phone(phone),
                'new_address': clean_string(address_line1),
                'existing_donor_id': person.get('donor_id'),
                'existing_email': person.get('email'),
                'existing_phone': person.get('phone'),
                'existing_address': person.get('address_line1'),
            })
            return None, best_score
        else:
            return None, best_score

    @staticmethod
    def _normalize_address(address_line1, city):
        addr, cty = clean_string(address_line1), clean_string(city)
        if not addr or not cty: return None
        addr, cty = addr.lower().strip(), cty.lower().strip()
        replacements = {r'\bstreet\b': 'st', r'\bst\.\b': 'st', r'\bavenue\b': 'ave', r'\bave\.\b': 'ave', r'\bdrive\b': 'dr', r'\bdr\.\b': 'dr', r'\broad\b': 'rd', r'\brd\.\b': 'rd', r'\blane\b': 'ln', r'\bln\.\b': 'ln', r'\bcourt\b': 'ct', r'\bct\.\b': 'ct', r'\bcircle\b': 'cir', r'\bcir\.\b': 'cir', r'\bboulevard\b': 'blvd', r'\bblvd\.\b': 'blvd', r'\bplace\b': 'pl', r'\bpl\.\b': 'pl', r'\bnorth\b': 'n', r'\bsouth\b': 's', r'\beast\b': 'e', r'\bwest\b': 'w', r'\bapartment\b': 'apt', r'\bapt\.\b': 'apt', r'\bapt\b': 'apt', r'\bsuite\b': 'ste', r'\bste\.\b': 'ste', r'\bunit\b': 'unit', r'\bpo box\b': 'po box', r'\bp\.o\. box\b': 'po box', r'\bp\.o\.box\b': 'po box', r'\bpob\b': 'po box'}
        for pat, rep in replacements.items(): addr = re.sub(pat, rep, addr)
        addr = re.sub(r'\s+', ' ', re.sub(r'[^\w\s]', '', addr)).strip()
        cty = re.sub(r'\s+', ' ', re.sub(r'[^\w\s]', '', cty)).strip()
        return f"{addr}|{cty}"

    @staticmethod
    def _normalize_phone_digits(phone):
        if pd.isna(phone) or phone is None: return None
        digits = re.sub(r'\D', '', str(phone))
        return digits[-7:] if len(digits) >= 7 else None

    def register_person(self, first_name, last_name, email=None, source='unknown', **kwargs) -> str:
        first_name, last_name = clean_name(first_name) or 'Unknown', clean_name(last_name) or 'Unknown'
        email_clean = clean_email(email)

        existing_key, match_score = self.find_person(
            first_name, last_name, email,
            kwargs.get('phone'), kwargs.get('zip_code'),
            address_line1=kwargs.get('address_line1'), city=kwargs.get('city'),
        )

        if existing_key:
            self._merge_person(existing_key, first_name, last_name, email_clean, source, **kwargs)
            return existing_key

        person_key = make_person_key(first_name, last_name, email)
        if person_key in self.people: person_key = f"{person_key}:{hashlib.md5(str(datetime.now()).encode()).hexdigest()[:8]}"

        self.people[person_key] = {
            'person_key': person_key,
            'donor_id': self._next_donor_id(),
            'first_name': first_name,
            'last_name': last_name,
            'email': email_clean,
            'phone': clean_phone(kwargs.get('phone')),
            'address_line1': clean_string(kwargs.get('address_line1')),
            'address_line2': clean_string(kwargs.get('address_line2')),
            'city': clean_string(kwargs.get('city')),
            'state': clean_string(kwargs.get('state')),
            'zip_code': clean_zip(kwargs.get('zip_code')),
            'country': clean_string(kwargs.get('country')) or 'US',
            'donor_type': clean_string(kwargs.get('donor_type')) or 'Individual',
            'donor_status': clean_string(kwargs.get('donor_status')) or 'Active',
            'preferred_contact_method': clean_string(kwargs.get('preferred_contact_method')),
            'is_member': kwargs.get('is_member', False),
            'membership_level': clean_string(kwargs.get('membership_level')),
            'membership_start_date': kwargs.get('membership_start_date'),
            'membership_expiration_date': kwargs.get('membership_expiration_date'),
            'membership_status': clean_string(kwargs.get('membership_status')),
            'date_added': kwargs.get('date_added'),
            'last_contact_date': kwargs.get('last_contact_date'),
            'total_lifetime_donations': kwargs.get('total_lifetime_donations', 0),
            'notes': clean_string(kwargs.get('notes')),
            'gender': clean_string(kwargs.get('gender')),
            'is_primary_contact': kwargs.get('is_primary_contact', True),
            'household_id': kwargs.get('household_id'),
            '_source': source,
            '_source_priority': SOURCE_PRIORITY.get(source, 99),
            '_all_emails': set([email_clean]) if email_clean else set(),
        }

        if email_clean: self.email_index[email_clean] = person_key
        fn, ln = normalize_name_for_matching(first_name), normalize_name_for_matching(last_name)
        if fn and ln: self.name_index.setdefault(f"{fn}:{ln}", []).append(person_key)

        addr_norm = self._normalize_address(kwargs.get('address_line1'), kwargs.get('city'))
        if addr_norm: self._address_index.setdefault(addr_norm, []).append(person_key)

        ph_digits = self._normalize_phone_digits(kwargs.get('phone'))
        if ph_digits: self._phone_index.setdefault(ph_digits, []).append(person_key)

        return person_key

    def _merge_person(self, person_key: str, first_name, last_name, email, source, **kwargs):
        """Merge new data into existing person record, now with JSON resolution support."""
        person = self.people[person_key]
        new_priority = SOURCE_PRIORITY.get(source, 99)
        existing_priority = person.get('_source_priority', 99)
        p_display = f"{person.get('first_name')} {person.get('last_name')} (donor_id={person.get('donor_id')})"

        # --- Email Conflict & Resolution Engine ---
        if email:
            person['_all_emails'].add(email)
            if email not in self.email_index: self.email_index[email] = person_key
            existing_email = person.get('email')

            if existing_email and email != existing_email:
                # Reconstruct the ID generated by manual_reviewer.py
                w_id = f"EMAIL_CONFLICT_{person.get('donor_id')}_{len(self.warnings)}"
                res = self.resolutions.get(w_id)

                if res:
                    action = res.get('action')
                    if action == 'keep_default':
                        email = existing_email
                    elif action == 'keep_alternative':
                        pass  # keep the new 'email' variable as is
                    elif action == 'keep_both':
                        email = res.get('primary_value')
                        person['notes'] = f"{person.get('notes', '')} | Alt Email: {res.get('alternate_value')}".strip(
                            ' |')
                    elif action == 'keep_personal_and_affiliate':
                        email = res.get('personal_value')
                        # Queue the affiliation to be handled at the end
                        person['_pending_affiliations'] = person.get('_pending_affiliations', [])
                        person['_pending_affiliations'].append(res.get('org_name'))
                    elif action == 'split_to_new_person':
                        # Queue the spouse to be created at the end
                        person['_pending_spouses'] = person.get('_pending_spouses', [])
                        person['_pending_spouses'].append({
                            'first_name': res.get('first_name'),
                            'last_name': res.get('last_name'),
                            'email': email
                        })
                        email = existing_email  # Keep Jane's email on Jane's record
                else:
                    self.warnings.append({
                        'type': 'EMAIL_CONFLICT', 'donor_id': person.get('donor_id'),
                        'kept_value': existing_email if new_priority >= existing_priority else email,
                        'alt_value': email if new_priority >= existing_priority else existing_email,
                        # ... other metadata ...
                    })

                # --- Phone Conflict & Resolution Engine ---
                new_phone = clean_phone(kwargs.get('phone'))
                existing_phone = person.get('phone')
                if new_phone and existing_phone and new_phone != existing_phone:
                    w_id = f"PHONE_CONFLICT_{person.get('donor_id')}_{len(self.warnings)}"
                    res = self.resolutions.get(w_id)
                    if res:
                        action = res.get('action')
                        if action == 'keep_default':
                            new_phone = existing_phone
                        elif action == 'keep_alternative':
                            pass  # Keep the new_phone as is
                        elif action == 'keep_both':
                            new_phone = res.get('primary_value')
                            person[
                                'notes'] = f"{person.get('notes', '')} | Alt Phone: {res.get('alternate_value')}".strip(
                                ' |')
                        elif action == 'keep_personal_and_affiliate':
                            new_phone = res.get('personal_value')
                            person['_pending_affiliations'] = person.get('_pending_affiliations', [])
                            person['_pending_affiliations'].append(res.get('org_name'))
                        elif action == 'split_to_new_person':
                            person['_pending_spouses'] = person.get('_pending_spouses', [])
                            person['_pending_spouses'].append({
                                'first_name': res.get('first_name'),
                                'last_name': res.get('last_name'),
                                'phone': new_phone
                            })
                            new_phone = existing_phone
                    else:
                        # The full dictionary that prevents the error:
                        self.warnings.append({
                            'type': 'PHONE_CONFLICT',
                            'message': f"Different phones for {p_display}",
                            'donor_id': person.get('donor_id'),
                            'person_name': p_display,
                            'kept_value': existing_phone if new_priority >= existing_priority else new_phone,
                            'kept_source': person.get('_source') if new_priority >= existing_priority else source,
                            'alt_value': new_phone if new_priority >= existing_priority else existing_phone,
                            'alt_source': source if new_priority >= existing_priority else person.get('_source'),
                        })
                kwargs['phone'] = new_phone

        # --- Final Merge Fields (Priority Based) ---
        merge_fields = ['phone', 'address_line1', 'city', 'state', 'zip_code', 'membership_level', 'gender']
        for field in merge_fields:
            new_val = kwargs.get(field)
            if new_val and (person.get(field) is None or new_priority < existing_priority):
                person[field] = new_val

        if email: person['email'] = email
        # --- Phone Conflict & Resolution ---
        new_phone, existing_phone = clean_phone(kwargs.get('phone')), person.get('phone')
        if new_phone and existing_phone and new_phone != existing_phone:
            w_id = f"PHONE_CONFLICT_{person.get('donor_id')}_{len(self.warnings)}"
            res = self.resolutions.get(w_id)
            if res:
                action = res.get('action')
                if action == 'keep_default': new_phone = existing_phone
                elif action == 'keep_both':
                    new_phone = res.get('primary_value')
                    person['notes'] = f"{person.get('notes', '')} | Alt Phone: {res.get('alternate_value')}".strip(' |')
                elif action == 'keep_personal_and_affiliate':
                    new_phone = res.get('personal_value')
                    person['_pending_affiliations'] = person.get('_pending_affiliations', [])
                    person['_pending_affiliations'].append(res.get('org_name'))
                elif action == 'split_to_new_person':
                    person['_pending_spouses'] = person.get('_pending_spouses', [])
                    person['_pending_spouses'].append({'first_name': res.get('first_name'), 'last_name': res.get('last_name'), 'phone': new_phone})
                    new_phone = existing_phone
            else:
                self.warnings.append({
                    'type': 'PHONE_CONFLICT', 'message': f"Different phones for {p_display}", 'donor_id': person.get('donor_id'),
                    'person_name': p_display, 'kept_value': existing_phone if new_priority >= existing_priority else new_phone,
                    'kept_source': person.get('_source') if new_priority >= existing_priority else source,
                    'alt_value': new_phone if new_priority >= existing_priority else existing_phone,
                    'alt_source': source if new_priority >= existing_priority else person.get('_source'),
                })
        kwargs['phone'] = new_phone

        # --- Address Conflict & Resolution ---
        new_address, existing_address = clean_string(kwargs.get('address_line1')), person.get('address_line1')
        if new_address and existing_address:
            n_norm, e_norm = self._normalize_address(new_address, kwargs.get('city')), self._normalize_address(existing_address, person.get('city'))
            if n_norm and e_norm and n_norm != e_norm:
                w_id = f"ADDRESS_CONFLICT_{person.get('donor_id')}_{len(self.warnings)}"
                res = self.resolutions.get(w_id)
                if res:
                    action = res.get('action')
                    if action == 'keep_default':
                        kwargs['address_line1'], kwargs['city'], kwargs['state'], kwargs['zip_code'] = existing_address, person.get('city'), person.get('state'), person.get('zip_code')
                    elif action == 'keep_personal_and_affiliate':
                        person['_pending_affiliations'] = person.get('_pending_affiliations', [])
                        person['_pending_affiliations'].append(res.get('org_name'))
                        if res.get('personal_value') == existing_address:
                            kwargs['address_line1'], kwargs['city'], kwargs['state'], kwargs['zip_code'] = existing_address, person.get('city'), person.get('state'), person.get('zip_code')
                else:
                    self.warnings.append({
                        'type': 'ADDRESS_CONFLICT', 'message': f"Different addresses for {p_display}", 'donor_id': person.get('donor_id'),
                        'person_name': p_display, 'kept_value': f"{existing_address}, {person.get('city') or ''}" if new_priority >= existing_priority else f"{new_address}, {clean_string(kwargs.get('city')) or ''}",
                        'kept_source': person.get('_source') if new_priority >= existing_priority else source,
                        'alt_value': f"{new_address}, {clean_string(kwargs.get('city')) or ''}" if new_priority >= existing_priority else f"{existing_address}, {person.get('city') or ''}",
                        'alt_source': source if new_priority >= existing_priority else person.get('_source'),
                    })

        # Final merge loop
        merge_fields = ['phone', 'address_line1', 'address_line2', 'city', 'state', 'zip_code', 'country', 'donor_type', 'donor_status', 'preferred_contact_method', 'membership_level', 'membership_start_date', 'membership_expiration_date', 'membership_status', 'date_added', 'last_contact_date', 'gender']
        for field in merge_fields:
            new_val = kwargs.get(field)
            if field == 'zip_code': new_val = clean_zip(new_val)
            elif field in ('address_line1', 'address_line2', 'city', 'state', 'country', 'donor_type', 'donor_status', 'preferred_contact_method', 'membership_level', 'membership_status', 'gender'): new_val = clean_string(new_val)
            if new_val is not None and (person.get(field) is None or new_priority < existing_priority): person[field] = new_val

        if email and (person.get('email') is None or new_priority < existing_priority): person['email'] = email
        if kwargs.get('is_member'): person['is_member'] = True
        if kwargs.get('total_lifetime_donations') and kwargs.get('total_lifetime_donations') > (person.get('total_lifetime_donations') or 0): person['total_lifetime_donations'] = kwargs.get('total_lifetime_donations')
        if clean_string(kwargs.get('notes')): person['notes'] = f"{person.get('notes') or ''} | {clean_string(kwargs.get('notes'))}".strip(' |')
        if new_priority < existing_priority: person['_source_priority'], person['_source'] = new_priority, source

    def find_or_create_household(self, person_key: str, household_name: str = None, address: str = None, city: str = None, state: str = None, zip_code: str = None, phone: str = None, **kwargs) -> int:
        addr_key = make_address_key(address, city, zip_code)
        if addr_key and addr_key in self.households:
            hh = self.households[addr_key]
            if phone and not hh.get('phone'): hh['phone'] = clean_phone(phone)
            return hh['household_id']

        hh_id = self._next_household_id()
        person = self.people.get(person_key, {})
        if not household_name: household_name = f"{person.get('first_name', '')} {person.get('last_name', '')} Household".strip()

        self.households[addr_key if addr_key else f"hh_{hh_id}"] = {
            'household_id': hh_id, 'household_name': household_name, 'primary_contact_id': person.get('donor_id'),
            'address_line1': clean_string(address), 'address_line2': clean_string(kwargs.get('address_line2')),
            'city': clean_string(city), 'state': clean_string(state), 'zip_code': clean_zip(zip_code), 'country': clean_string(kwargs.get('country')) or 'US',
            'phone': clean_phone(phone), 'is_member': kwargs.get('is_member', False), 'membership_level': clean_string(kwargs.get('membership_level')),
            'membership_start_date': kwargs.get('membership_start_date'), 'membership_expiration_date': kwargs.get('membership_expiration_date'),
            'membership_status': clean_string(kwargs.get('membership_status')), 'total_lifetime_donations': 0, 'notes': clean_string(kwargs.get('notes')),
            '_address_key': addr_key, '_member_keys': [person_key],
        }
        return hh_id

    def find_or_create_organization(self, org_name: str, **kwargs) -> int:
        org_name_clean = clean_string(org_name)
        if not org_name_clean: return None
        norm_key = normalize_for_matching(org_name_clean)
        if norm_key in self.organizations: return self.organizations[norm_key]['organization_id']

        org_id = self._next_org_id()
        self.organizations[norm_key] = {
            'organization_id': org_id, 'organization_name': org_name_clean, 'organization_type': clean_string(kwargs.get('organization_type')),
            'tax_id': clean_string(kwargs.get('tax_id')), 'website': clean_string(kwargs.get('website')),
            'address_line1': clean_string(kwargs.get('address_line1')), 'address_line2': clean_string(kwargs.get('address_line2')),
            'city': clean_string(kwargs.get('city')), 'state': clean_string(kwargs.get('state')), 'zip_code': clean_zip(kwargs.get('zip_code')),
            'country': clean_string(kwargs.get('country')) or 'US', 'phone': clean_phone(kwargs.get('phone')),
            'is_member': kwargs.get('is_member', False), 'membership_level': clean_string(kwargs.get('membership_level')),
            'membership_start_date': kwargs.get('membership_start_date'), 'membership_expiration_date': kwargs.get('membership_expiration_date'),
            'membership_status': clean_string(kwargs.get('membership_status')), 'is_vendor': kwargs.get('is_vendor', False),
            'vendor_category': clean_string(kwargs.get('vendor_category')), 'total_lifetime_donations': 0, 'notes': clean_string(kwargs.get('notes')),
        }
        return org_id

