}

def classify_file(filepath: str, df: pd.DataFrame) -> Optional[str]:
    filename = os.path.basename(filepath).lower()
    columns = set(df.columns.tolist())

    filename_matches = [src for src, kws in FILENAME_PATTERNS.items() if any(kw in filename for kw in kws)]
    if len(filename_matches) == 1: return filename_matches[0]

    scores = {}
    for src, fp in COLUMN_FINGERPRINTS.items():
        if not set(fp.get('required', [])).issubset(columns): continue
        strong = set(fp.get('strong', []))
        score = len(strong.intersection(columns)) / (len(strong) or 1)
        if fp.get('max_columns') and len(columns) > fp.get('max_columns'): score *= 0.3
        scores[src] = score

    if scores and max(scores.values()) > 0:
        return max(scores, key=scores.get)
    if filename_matches:
        return filename_matches[0]
    return None

def scan_input_folder(input_dir: str) -> Dict[str, List[Tuple[str, pd.DataFrame]]]:
    if not os.path.isdir(input_dir): return {}
    classified = defaultdict(list)
    files = [f for f in os.listdir(input_dir) if f.lower().endswith(('.csv', '.xlsx', '.xls')) and not f.startswith('~')]

    for filename in sorted(files):
        filepath = os.path.join(input_dir, filename)
        df = DataLoader.load_file(filepath)
        if df is None or df.empty: continue
        source_type = classify_file(filepath, df)
        if source_type:
            classified[source_type].append((filepath, df))

    return classified

