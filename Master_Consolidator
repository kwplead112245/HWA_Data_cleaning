FILENAME_PATTERNS = {
    'qgiv': ['transaction', 'qgiv'],
    'quickbooks': ['qb_', 'quickbooks'],
    'old_names': ['names'],
    'volunteer_db': ['volunteer'],
    'sf_contacts': ['contact export', 'contact_export', 'sf_contacts', 'contacts'],
    'sf_accounts': ['sf_accounts', 'account'],
    'sf_households': ['household', 'cleaned_household'],
}

COLUMN_FINGERPRINTS = {
    'qgiv': {'required': ['Transaction ID', 'Total Amount'], 'strong': ['Line Item', 'Batch Date', 'Form Name', 'Recurring ID']},
    'quickbooks': {'required': ['name', 'amount'], 'strong': ['type', 'date'], 'max_columns': 6},
    'old_names': {'required': ['FName', 'LName'], 'strong': ['SpousesName', 'HH Number', 'YrJoined', 'Dues']},
    'volunteer_db': {'required': ['First Name', 'Last Name'], 'strong': ['LAST_CHANGED'], 'max_columns': 10},
    'sf_contacts': {'required': ['Contact ID'], 'strong': ['Account ID', 'Volunteer Status', 'Membership Join Date']},
