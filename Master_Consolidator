def main():
    config = Config()
    logger.info("=" * 60)
    logger.info("HAYWOOD WATERWAYS - DATA CONSOLIDATION")
    logger.info("=" * 60)

    classified_files = scan_input_folder(config.INPUT_DIR)
    if not classified_files: return

    consolidator = MasterConsolidator(config)

    process_map = {
        'qgiv': ('process_qgiv', DataLoader.load_qgiv),
        'quickbooks': ('process_quickbooks', None),
        'old_names': ('process_old_names', DataLoader.load_old_names),
        'volunteer_db': ('process_volunteer_db', None),
        'sf_contacts': ('process_sf_contacts', DataLoader.load_sf_contacts),
        'sf_accounts': ('process_sf_accounts', DataLoader.load_sf_accounts),
        'sf_households': ('process_sf_households', None),
    }

    for source_type in sorted(classified_files.keys(), key=lambda x: SOURCE_PRIORITY.get(x, 99)):
        method_name, loader_fn = process_map.get(source_type, (None, None))
        processor = getattr(consolidator, method_name, None)
        for filepath, df in classified_files[source_type]:
            logger.info(f"\nProcessing {os.path.basename(filepath)} as {source_type}...")
            filtered_df = loader_fn(filepath) if loader_fn else df
            if filtered_df is not None: processor(filtered_df)

    # Apply manual splits/org affiliations from JSON before deduping/households
    consolidator.process_pending_resolutions()
    consolidator.dedupe_donations()
    consolidator.assign_households()
    consolidator.calculate_memberships()

    # THE CONTINGENCY CHECK
    actionable_warnings = [w for w in consolidator.warnings if w.get('type') in ('REVIEW_NEEDED', 'EMAIL_CONFLICT', 'PHONE_CONFLICT', 'ADDRESS_CONFLICT')]

    if actionable_warnings:
        logger.warning(f"\n🛑 HALTING EXPORT: {len(actionable_warnings)} unresolved conflicts found.")
        os.makedirs(config.OUTPUT_DIR, exist_ok=True)
        warn_path = os.path.join(config.OUTPUT_DIR, 'consolidation_warnings.csv')
        try:
            pd.DataFrame(consolidator.warnings).to_csv(warn_path, index=False)
            logger.info(f"  1. Conflicts quarantined to {warn_path}")
            logger.info("  2. Please run 'manual_reviewer.py' to resolve these.")
        except PermissionError:
            logger.error(f"\n❌ PERMISSION DENIED: Could not save {warn_path}.")
            logger.error("Please close the file in Excel and run the script again.")
        return

    consolidator.export_all(config.OUTPUT_DIR)
    logger.info("\nDONE! All conflicts resolved. Output saved.")

if __name__ == "__main__":
    main()