class DataLoader:
    @staticmethod
    def load_file(filepath: str, file_type: str = 'csv') -> Optional[pd.DataFrame]:
        if not os.path.exists(filepath): return None
        if file_type == 'excel' or filepath.lower().endswith(('.xlsx', '.xls')):
            try: return pd.read_excel(filepath, engine='openpyxl')
            except Exception: return None
        else:
            for enc in ['utf-8', 'latin1', 'cp1252']:
                try: return pd.read_csv(filepath, encoding=enc, low_memory=False)
                except Exception: continue
        return None

    @staticmethod
    def load_qgiv(filepath: str) -> Optional[pd.DataFrame]:
        df = DataLoader.load_file(filepath)
        if df is not None and 'Status' in df.columns:
            df = df[~df['Status'].str.lower().str.strip().isin(['refunded', 'failed', 'declined', 'cancelled', 'void', 'error'])].copy()
        return df

    @staticmethod
    def load_old_names(filepath: str) -> Optional[pd.DataFrame]:
        return DataLoader.load_file(filepath, 'excel' if filepath.endswith(('.xlsx', '.xls')) else 'csv')

    @staticmethod
    def load_sf_contacts(filepath: str) -> Optional[pd.DataFrame]:
        df = DataLoader.load_file(filepath)
        return df[df['Deleted'] != True].copy() if df is not None and 'Deleted' in df.columns else df

    @staticmethod
    def load_sf_accounts(filepath: str) -> Optional[pd.DataFrame]:
        df = DataLoader.load_file(filepath)
        return df[df['IsDeleted'] != True].copy() if df is not None and 'IsDeleted' in df.columns else df

def parse_concatenated_names(fname, lname, spousesname=None):
    if pd.isna(fname) and pd.isna(lname): return []
    fname, lname = str(fname).strip() if pd.notna(fname) else '', str(lname).strip() if pd.notna(lname) else ''
    people = []

    if re.search(r'\s+(&|and|And)\s+', fname):
        parts = re.split(r'\s+(&|and|And)\s+', fname)
        p1, p2 = parts[0].strip().split(), (parts[2].strip().split() if len(parts)>2 else [])
        people.append({'first_name': p1[0], 'last_name': ' '.join(p1[1:]) if len(p1)>1 else lname})
        if p2: people.append({'first_name': p2[0], 'last_name': ' '.join(p2[1:]) if len(p2)>1 else lname})
    elif re.search(r'(&|and|And)\s*$', fname):
        people.append({'first_name': re.sub(r'\s*(&|and|And)\s*$', '', fname).strip(), 'last_name': lname})
    elif re.search(r'\s+(&|and|And)\s+', lname):
        parts = re.split(r'\s+(&|and|And)\s+', lname)
        p1_lname, p2 = parts[0].strip(), (parts[2].strip().split() if len(parts)>2 else [])
        people.append({'first_name': fname, 'last_name': p1_lname})
        if p2: people.append({'first_name': p2[0], 'last_name': ' '.join(p2[1:]) if len(p2)>1 else p1_lname})
    else:
        if fname and lname: people.append({'first_name': fname, 'last_name': lname})
        elif fname:
            fp = fname.split()
            people.append({'first_name': fp[0], 'last_name': ' '.join(fp[1:]) if len(fp)>1 else ''})

    if pd.notna(spousesname) and str(spousesname).strip() and len(people) < 2:
        sp = str(spousesname).strip().split()
        people.append({'first_name': sp[0], 'last_name': ' '.join(sp[1:]) if len(sp)>1 else (people[0]['last_name'] if people else '')})
    return people

