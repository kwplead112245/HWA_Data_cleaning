    def _is_household_account(self, name: str, row: pd.Series) -> bool:
        n_lower = name.lower().strip()
        if 'household' in n_lower: return True
        at = clean_string(row.get('npe01__SYSTEM_AccountType__c') or row.get('Type'))
        if at and ('household' in at.lower() or 'individual' in at.lower()): return True
        if pd.notna(row.get('npe01__One2OneContact__c')) and str(row.get('npe01__One2OneContact__c')).strip(): return True
        if not is_organization_name(name): return True
        return False

